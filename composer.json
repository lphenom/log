{
    "name": "lphenom/log",
    "description": "KPHP-compatible logging package for the LPhenom framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["log", "logger", "logging", "kphp", "lphenom"],
    "homepage": "https://github.com/lphenom/log",
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "squizlabs/php_codesniffer": "^3.10",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "LPhenom\\Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Log\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --colors=always",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs"
    }
}

